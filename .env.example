# Google Sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# From the service account JSON: "client_email"
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# From the service account JSON: "private_key" — keep quotes; use \n for newlines inside the key
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional (default Sheet1!A:B). First row can be headers: Timestamp | Email
# WAITLIST_SHEET_RANGE=Sheet1!A:B
